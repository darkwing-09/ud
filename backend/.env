# Application
APP_NAME="EduCore School Management Platform"
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=EduCoreDevelopmentSecretKey1234567890!@#
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
API_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://educore:educore_pass@postgres:5432/educore_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_ECHO=false

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2
REDIS_RESULT_DB=3

# JWT
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_RESET_TOKEN_EXPIRE_HOURS=2
JWT_VERIFY_TOKEN_EXPIRE_HOURS=24

# Celery
CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=redis://localhost:6379/3

# File Storage (Cloudflare R2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=educore-files
R2_PUBLIC_URL=http://localhost:8000/static
R2_REGION=auto

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@educore.in
EMAIL_FROM_NAME="EduCore"
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_TLS=false
SMTP_USER=
SMTP_PASSWORD=

# SMS (MSG91)
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_SENDER_ID=EDCORE
MSG91_TEMPLATE_ID_OTP=your-otp-template-id
MSG91_TEMPLATE_ID_ABSENCE=your-absence-template-id
MSG91_TEMPLATE_ID_FEE=your-fee-template-id

# Payment (Razorpay)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Sentry
SENTRY_DSN=

# PII Encryption (AES-256)
PII_ENCRYPTION_KEY=RHdnIj3tqyM_KfU1zC4rNfx_5KFf6R6S6QRWYJF9eZE=

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# Feature Flags
FEATURE_WHATSAPP_ENABLED=false
FEATURE_AI_ANALYTICS=false
FEATURE_MULTI_SCHOOL=true
FEATURE_LIBRARY_MODULE=false
FEATURE_BUS_TRACKING=false

# Limits & Thresholds
MAX_FILE_UPLOAD_MB=10
MAX_BULK_IMPORT_ROWS=2000
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_API_PER_MINUTE=200
MIN_ATTENDANCE_PERCENTAGE=75
DEFAULT_LATE_FEE_PER_DAY=10

# TOTP / 2FA
TOTP_ISSUER_NAME=EduCore
